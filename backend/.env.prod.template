# PostgreSQL Credentials (set real values in deployment)
POSTGRES_USER=<production-user>
POSTGRES_PASSWORD=<secure-password>
POSTGRES_DB=evaluador_db
DB_HOST=db
DB_PORT=5432

# AI / RAG Configuration
OPENAI_API_KEY=<your_key_here>
OPENAI_MODEL=<your_model_here>
GEMINI_API_KEY=<your_key_here>
GEMINI_MODEL=<your_model_here>
VERTEX_ENABLED=true
GCP_PROJECT_ID=<your_gcp_project_id>
GCP_LOCATION=europe-west1
GEMINI_MODEL_VERTEX=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL_VERTEX=text-embedding-005
GOOGLE_APPLICATION_CREDENTIALS_JSON=<service_account_json_string>
GROQ_API_KEY=<your_key_here>
GROQ_MODEL=<your_model_here>

# Abuse protection / cooldown
ENABLE_DEFAULT_PROVIDER_COOLDOWN=true
DEFAULT_PROVIDER_COOLDOWN_SECONDS=900
ENABLE_EVALUATION_RATE_LIMIT=true
EVALUATION_RATE_LIMIT_MAX_REQUESTS=5
EVALUATION_RATE_LIMIT_WINDOW_SECONDS=600

# Langsmith configuration
export LANGSMITH_TRACING=true
export LANGSMITH_ENDPOINT=https://api.smith.langchain.com
export LANGSMITH_API_KEY=<your_key_here>
export LANGSMITH_PROJECT="evaluAI"

# Production Settings
ENVIRONMENT=production
LOG_LEVEL=ERROR
