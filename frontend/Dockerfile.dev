FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy the rest of the code is handled by volumes in compose
# for hot-reloading, but we expose the Vite port
EXPOSE 5173

# Run Vite in dev mode with network access
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]