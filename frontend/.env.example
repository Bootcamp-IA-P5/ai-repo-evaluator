# Server-side URL for the FastAPI backend.
# Used by app/api/v1/[...path]/route.ts to proxy requests server-side.
# Defaults to http://backend:8000 (Docker Compose service name on eval-network).
# Override for non-Docker setups, e.g.: BACKEND_URL=http://localhost:8000
BACKEND_URL=http://backend:8000

# API Keys - BYOK (Bring Your Own Key)
# API keys should NEVER be stored in this file or committed to the repository.
# In this project, keys are entered by users at runtime through the UI
# and are NOT stored in frontend environment variables or the bundle.
# NEXT_PUBLIC_OPENAI_API_KEY=
# NEXT_PUBLIC_GROQ_API_KEY=
# NEXT_PUBLIC_ANTHROPIC_API_KEY=
